# ══════════════════════════════════════════════════════════════════
#  PraxisML — Variables de entorno
#
#  Copia este archivo como .env y rellena tus valores reales.
#  NUNCA subas .env al repositorio (está en .gitignore).
#
#  Orden de precedencia (mayor → menor):
#    1. Variables de entorno del sistema / contenedor
#    2. Archivo .env
#    3. Defaults en app/core/config.py (solo para development)
# ══════════════════════════════════════════════════════════════════

# ── Entorno ─────────────────────────────────────────────────────
# Valores válidos: development | staging | production | testing
ENVIRONMENT=development

# ── Base de datos ───────────────────────────────────────────────
# Debe comenzar con postgresql://
DATABASE_URL=postgresql://postgres:postgres@db:5432/praxisml_db

# ── Redis / Celery ──────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── MLFlow ──────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── Seguridad JWT ───────────────────────────────────────────────
# ⚠️  OBLIGATORIO en production/staging — la app NO arranca con el default.
#     Genera una clave segura: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA_256_BITS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 días

# Proveedor externo opcional (Clerk / Auth0)
# EXTERNAL_AUTH_JWKS_URL=https://YOUR_DOMAIN/.well-known/jwks.json
# EXTERNAL_AUTH_AUDIENCE=https://your-api-audience
# EXTERNAL_AUTH_ISSUER=https://your-issuer

# ── CORS ────────────────────────────────────────────────────────
# Orígenes permitidos (coma-separados)
# Desarrollo: http://localhost:3000
# Producción: https://app.praxisml.ai,https://praxisml.ai
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ─────────────────────────────────────────────────────
# URL de la API para el frontend (usada por Next.js)
# En producción, cambiar a la URL de tu backend (ej: https://api.praxisml.ai)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Rate Limiting ───────────────────────────────────────────────
# Formato: N/period donde period ∈ {second, minute, hour, day}
RATE_LIMIT_TRAINING=10/minute
RATE_LIMIT_INFERENCE=30/minute

# ── Almacenamiento ──────────────────────────────────────────────
# Valores válidos: local | minio | s3
STORAGE_BACKEND=minio

# MinIO (self-hosted, local / staging)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=praxisml
MINIO_REGION=us-east-1

# AWS S3 (producción cloud) — descomenta si usas S3
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_DEFAULT_REGION=eu-west-1
# S3_BUCKET=praxisml-prod
