# ══════════════════════════════════════════════════════════════════
#  Antigravity SaaS — Variables de entorno
#  Copia este archivo como .env y rellena tus valores reales.
#  NUNCA subas .env al repositorio (está en .gitignore).
# ══════════════════════════════════════════════════════════════════

# ── Entorno ─────────────────────────────────────────────────────
# Valores: development | staging | production
ENVIRONMENT=development

# ── Base de datos ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/antigravity_db

# ── Redis / Celery ──────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── MLFlow ──────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── Seguridad JWT ───────────────────────────────────────────────
SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA_256_BITS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 días

# Proveedor externo opcional (Clerk / Auth0)
# EXTERNAL_AUTH_JWKS_URL=https://YOUR_DOMAIN/.well-known/jwks.json

# ── CORS ────────────────────────────────────────────────────────
# Orígenes permitidos (coma-separados)
# Desarrollo: http://localhost:3000
# Producción: https://app.antigravity.ai,https://antigravity.ai
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_TRAINING=10/minute
RATE_LIMIT_INFERENCE=30/minute

# ── Almacenamiento ──────────────────────────────────────────────
# Valores: local | minio | s3
STORAGE_BACKEND=minio

# MinIO (self-hosted, local / staging)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=antigravity
MINIO_REGION=us-east-1

# AWS S3 (producción cloud) — dejar vacío si no se usa
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_DEFAULT_REGION=eu-west-1
# S3_BUCKET=antigravity-prod
